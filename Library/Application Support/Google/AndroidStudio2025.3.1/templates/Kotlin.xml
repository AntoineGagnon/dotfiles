  <template name="lazycol" value="LazyColumn(&#10;    modifier = Modifier.fillMaxSize(),&#10;    contentPadding = PaddingValues($DP$.dp)&#10;) {&#10;    items($COUNT$) { $ITEM$ -&gt;&#10;        $END$&#10;    }&#10;}" description="LazyColumn with items" toReformat="true" toShortenFQNames="true">
